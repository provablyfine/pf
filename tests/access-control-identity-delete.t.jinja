Initialize server and login
  $ bash $TESTDIR/fixture.sh
  .* (re)
  $ ROOT_ID=$(pfa -c config.json identity list -n root -q)
  $ source $TESTDIR/access-control-identity-fixture.sh
  .* (re)

{% for grant in [
  "--delete",
  "--delete --tag id=person",
  "--delete --boundary boundary",
  "--delete --tag id=person --boundary boundary",
]
%}
Check that grant "{{grant}}" is actually enforcing access control
  $ pfa -c config.json identity create -n user4 -b boundary -t $PERSON_ID
  $ USER4_ID=$(pfa -c config.json identity list -n user4 -q)
  $ pfa -c user1.json identity delete -i $USER4_ID
  Unable to delete identity. Not allowed to delete identity
  [2]
  $ pfa -c config.json grant identity {{grant}} | pfa -c config.json role grant -i $ROLE_ID --add
  $ pfa -c user1.json identity delete -i $USER4_ID
  $ pfa -c config.json role read -i $ROLE_ID -f json | jq '.grant_list[-1]' | pfa -c config.json role grant -i $ROLE_ID --del
{% endfor %}

{% for grant in [
  "--delete --name user4",
]
%}
Check that grant "{{grant}}" is actually enforcing access control
and becomes invalid after the identity is deleted
  $ pfa -c config.json identity create -n user4 -b boundary -t $PERSON_ID
  $ USER4_ID=$(pfa -c config.json identity list -n user4 -q)
  $ pfa -c user1.json identity delete -i $USER4_ID
  Unable to delete identity. Not allowed to delete identity
  [2]
  $ pfa -c config.json grant identity {{grant}} | pfa -c config.json role grant -i $ROLE_ID --add
  $ pfa -c user1.json identity delete -i $USER4_ID
  $ pfa -c config.json role read -i $ROLE_ID
  id           2
  name         role
  description
  member       user1
  grant        type:       invalid
               filter:     !
               permission: !
  $ pfa -c config.json role read -i $ROLE_ID -f json | jq '.grant_list[-1]' | pfa -c config.json role grant -i $ROLE_ID --del
{% endfor %}


