Initialize server and login
  $ bash $TESTDIR/fixture.sh
  .* (re)
  $ ROOT_ID=$(idbctl admin identity list -n root -q)
  $ source $TESTDIR/idb-access-control-identity-fixture.sh
  .* (re)

{% for grant, expected in [
  ("--read", (1,2,3)),
  ("--read --name user2", (3,)),
]
%}
Check that grant "{{grant}}" is actually enforcing access control
  $ idbctl admin grant identity {{grant}} | idbctl admin role grant -i $ROLE_ID --add
  $ idbctl -c user1.json admin identity list -q
  {{ expected | join('\n  ') }}
  $ idbctl admin role read -i $ROLE_ID -f json | jq '.grant_list[-1]' | idbctl admin role grant -i $ROLE_ID --del
  $ idbctl -c user1.json admin identity list
{% endfor %}
