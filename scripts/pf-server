#!/usr/bin/env -S uv run -q --script
# /// script
# dependencies = [
#   "openapi-core",
#   "sqlalchemy",
#   "cryptography",
#   "fastapi",
#   "uvicorn",
#   "http-sfv",
#   "pytest",
#   "coverage",
#   "pydantic",
#   "pyjwt",
#   "pf",
# ]
# [tool.uv.sources]
# pf = { path = "../", editable = true }
# ///
import os

if __name__ == '__main__':
    cov = None
    if os.environ.get('COVERAGE_PROCESS_START'):
        import coverage
        cov = coverage.Coverage()
        cov.start()

    import pf.api.server
    try:
        pf.api.server.run()
    finally:
        if cov:
            cov.stop()
            cov.save()
